    <script>
        function showView(view) {
            const h = document.getElementById('home-view');
            const i = document.getElementById('investor-view');
            if (view === 'investors') { h.classList.remove('active'); i.classList.add('active'); window.scrollTo(0,0); } 
            else { h.classList.add('active'); i.classList.remove('active'); }
        }

        const sIn = document.getElementById('salaryInput');
        const aIn = document.getElementById('attritionInput');
        const res = document.getElementById('costResult');
        function update() {
            const total = (parseFloat(sIn.value)||0) * 2.13 * (parseFloat(aIn.value)||0);
            res.innerText = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(total);
        }
        sIn.addEventListener('input', update); aIn.addEventListener('input', update);

        window.onload = function() {
            const ctx = document.getElementById('burnoutChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Oversight', 'Execution', 'Ambiguity', 'Masking Tax'],
                    datasets: [{
                        data: [85, 92, 78, 95],
                        backgroundColor: ['#064680', '#064680', '#064680', '#58bbc2'],
                        borderRadius: 8, barThickness: 40
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, scales: { y: { display: false }, x: { grid: { display: false } } }, plugins: { legend: { display: false } } }
            });
        };

        const vS = document.getElementById('velocitySlider');
        const lF = document.getElementById('loadFill');
        const mB = document.getElementById('managerBlock');
        const sT = document.getElementById('strainText');
        const sB = document.getElementById('statusBadge');
        vS.addEventListener('input', (e) => {
            const v = e.target.value;
            lF.style.width = (20 + v * 0.8) + '%';
            if (v <= 35) { sB.innerText = 'Status: Optimal'; sB.style.background = '#58bbc21a'; sT.innerText = 'Integrity: 100%'; mB.classList.remove('fracture-alert'); lF.style.background = '#58bbc2'; }
            else if (v <= 75) { sB.innerText = 'Status: Strained'; sB.style.background = '#0646801a'; sT.innerText = 'Warning: Fatigue'; mB.classList.remove('fracture-alert'); lF.style.background = '#064680'; }
            else { sB.innerText = 'CRITICAL: FAILURE'; sB.style.background = '#fee2e2'; sT.innerText = 'Integrity: 12%'; mB.classList.add('fracture-alert'); lF.style.background = '#ea580c'; }
        });
    </script>
</body>
