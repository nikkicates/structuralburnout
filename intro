                <a href="https://www.linkedin.com/in/nikkicatesmiller" target="_blank" class="px-8 py-4 border border-white/20 rounded-lg font-bold hover:bg-white/5 transition-all">LinkedIn Newsletter</a>
            </div>
            <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] text-slate-500 uppercase tracking-widest">
