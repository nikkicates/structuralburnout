    <script>
        // --- VIEW SWITCHER ---
        function showView(view) {
            const homeView = document.getElementById('home-view');
            const investView = document.getElementById('investor-view');
            
            if (view === 'investors') {
                homeView.classList.remove('active');
                investView.classList.add('active');
                window.scrollTo(0, 0);
            } else {
                homeView.classList.add('active');
                investView.classList.remove('active');
            }
        }

        // --- CALC COST LOGIC ---
        const salaryIn = document.getElementById('salaryInput');
        const attrIn = document.getElementById('attritionInput');
        const costRes = document.getElementById('costResult');

        function updateCost() {
            const salary = parseFloat(salaryIn.value) || 0;
            const attrition = parseFloat(attrIn.value) || 0;
            const total = salary * 2.13 * attrition;
            costRes.innerText = new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                maximumFractionDigits: 0
            }).format(total);
        }
        if(salaryIn) salaryIn.addEventListener('input', updateCost);
        if(attrIn) attrIn.addEventListener('input', updateCost);

        // --- CHART LOGIC ---
        window.onload = function() {
            const canvas = document.getElementById('burnoutChart');
            if (canvas) {
                const ctx = canvas.getContext('2d');
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: ['Oversight', 'Execution', 'Ambiguity', 'Masking Tax'],
                        datasets: [{
                            label: 'Structural Load %',
                            data: [85, 92, 78, 95],
                            backgroundColor: ['#064680', '#064680', '#064680', '#58bbc2'],
                            borderRadius: 8,
                            barThickness: 40
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true, max: 100, grid: { display: false } },
                            x: { grid: { display: false } }
                        },
                        plugins: { legend: { display: false } }
                    }
                });
            }
        };

        // --- STRESS TEST SIMULATOR ---
        const vSlider = document.getElementById('velocitySlider');
        const loadFill = document.getElementById('loadFill');
        const managerBlock = document.getElementById('managerBlock');
        const strainText = document.getElementById('strainText');
        const statusBadge = document.getElementById('statusBadge');
        const arrows = document.getElementById('loadArrows') ? document.getElementById('loadArrows').children : [];

        if (vSlider) {
            vSlider.addEventListener('input', (e) => {
                const val = e.target.value;
                const fillWidth = 20 + (val * 0.8);
                loadFill.style.width = fillWidth + '%';
                
                Array.from(arrows).forEach((arrow, i) => {
                    arrow.style.opacity = val > (i * 30) ? '1' : '0.2';
                    arrow.style.color = val > 70 ? '#ea580c' : (val > 40 ? '#064680' : '#cbd5e1');
                });

                if (val <= 35) {
                    statusBadge.innerText = 'Status: Optimal';
                    statusBadge.style.background = '#58bbc21a';
                    statusBadge.style.color = '#064680';
                    strainText.innerText = 'Structural Integrity: 100%';
                    managerBlock.classList.remove('fracture-alert');
                    loadFill.style.backgroundColor = '#58bbc2';
                } else if (val <= 75) {
                    statusBadge.innerText = 'Status: Strained';
                    statusBadge.style.background = '#0646801a';
                    statusBadge.style.color = '#064680';
                    strainText.innerText = 'Warning: Material Fatigue';
                    managerBlock.classList.remove('fracture-alert');
                    loadFill.style.backgroundColor = '#064680';
                } else {
                    statusBadge.innerText = 'CRITICAL: FAILURE IMMINENT';
                    statusBadge.style.background = '#fee2e2';
                    statusBadge.style.color = '#991b1b';
                    strainText.innerText = 'Structural Integrity: 12%';
                    managerBlock.classList.add('fracture-alert');
                    loadFill.style.backgroundColor = '#ea580c';
                }
            });
        }
    </script>
